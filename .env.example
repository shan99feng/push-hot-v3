# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB 连接
MONGODB_URI=mongodb://localhost:27017/ai-paper-daily

# Redis 连接
REDIS_URL=redis://localhost:6379

# OpenAI API 配置（用于论文摘要生成）
# 支持 OpenAI 兼容接口，如 DeepSeek、Qwen、Gemini 等
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.0-flash

# arXiv 配置
ARXIV_MAX_RESULTS=30
ARXIV_CATEGORIES=cs.CL,cs.AI,cs.LG,cs.CV,cs.IR

# HuggingFace 配置
HF_API_TOKEN=your_hf_token_here

# GitHub 配置（可选，提高 API 限制）
GITHUB_TOKEN=your_github_token_here

# 定时任务配置（cron 表达式）
# 默认每天 09:30 执行数据采集
CRON_SCHEDULE=30 9 * * *

# 最大摘要生成数量（控制 API 成本）
MAX_SUMMARY_COUNT=30

# 前端静态文件目录
STATIC_DIR=frontend
